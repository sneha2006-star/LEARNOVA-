<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Learnova - Study Material Platform</title>

    <style>
        @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&display=swap');
        
        body {
            font-family: 'Poppins', sans-serif;
            margin: 0;
            background: linear-gradient(to right, #fdfbfb, #ebedee);
            text-align: center;
            color: #333;
        }

        header {
            background: linear-gradient(90deg, #6a11cb, #2575fc);
            color: white;
            padding: 30px;
            box-shadow: 0 6px 12px rgba(0,0,0,0.15);
        }
        header h1 {
            margin: 0;
            font-size: 3em;
        }
        header p {
            font-size: 1.2em;
            font-weight: 500;
        }

        nav {
            background: #2c2c54;
            padding: 12px;
        }
        nav a {
            color: #fff;
            margin: 15px;
            text-decoration: none;
            font-weight: 600;
            transition: all 0.3s;
        }
        nav a:hover {
            color: #ff6b81;
        }

        section {
            padding: 50px 20px;
        }

        h2 {
            font-size: 2em;
            margin-bottom: 20px;
            color: #2575fc;
        }

        .card-container {
            display: flex;
            justify-content: center;
            gap: 25px;
            flex-wrap: wrap;
        }

        .card {
            background: linear-gradient(145deg, #ffecd2, #fcb69f);
            padding: 25px;
            width: 220px;
            border-radius: 15px;
            box-shadow: 0 10px 20px rgba(0,0,0,0.12);
            transition: transform 0.3s, box-shadow 0.3s;
            color: #2c2c2c;
        }
        .card:hover {
            transform: translateY(-7px);
            box-shadow: 0 15px 25px rgba(0,0,0,0.2);
        }

        button {
            padding: 12px 25px;
            background: linear-gradient(45deg, #ff6b81, #ffb347);
            color: white;
            border: none;
            border-radius: 50px;
            cursor: pointer;
            margin: 8px;
            font-weight: 600;
            transition: all 0.3s;
        }
        button:hover {
            transform: scale(1.05);
            background: linear-gradient(45deg, #ff9472, #ff6b81);
        }

        #quiz button {
            margin-top: 10px;
        }

        .coming-soon {
            background: #ffe3b3;
            border-left: 6px solid #ffb347;
            padding: 20px;
            margin: 20px auto;
            width: 80%;
            border-radius: 12px;
            font-size: 1.1em;
            font-weight: 600;
        }

        textarea {
            width: 80%;
            height: 90px;
            border-radius: 12px;
            border: 1px solid #ccc;
            padding: 12px;
            margin-top: 10px;
            resize: none;
            font-size: 1em;
        }

        .feedback-display {
            margin-top: 15px;
            text-align: left;
            width: 80%;
            margin-left: auto;
            margin-right: auto;
        }
        .feedback-display p {
            background: #d4f1f4;
            padding: 12px;
            border-radius: 12px;
            margin-bottom: 10px;
            color: #0b3d91;
            font-weight: 500;
        }

        footer {
            background: #2c2c54;
            color: white;
            padding: 25px;
        }
    </style>
</head>

<body>

<header>
    <h1>Learnova</h1>
    <p>Your Smart Study Material Platform</p>
</header>

<nav>
    <a href="#home">Home</a>
    <a href="#subjects">Subjects</a>
    <a href="#features">Features</a>
    <a href="#quiz">Quiz</a>
    <a href="#feedback">Feedback</a>
    <a href="#contact">Contact</a>
</nav>

<section id="home">
    <h2>Welcome to Learnova</h2>
    <p>All Study Materials in One Place - Notes, Videos, Quizzes & Resources</p>
    <button id="start-btn">Get Started</button>
</section>

<section id="subjects">
    <h2>Available Subjects</h2>
    <div class="card-container">
        <div class="card">
            <h3>Mathematics</h3>
            <p>Formulas, Notes and Practice Questions</p>
        </div>
        <div class="card">
            <h3>Physics</h3>
            <p>Concepts, Numericals and Diagrams</p>
        </div>
        <div class="card">
            <h3>Chemistry</h3>
            <p>Reactions, Theories and Important Topics</p>
        </div>
        <div class="card">
            <h3>Biology</h3>
            <p>Diagrams, Processes and Notes</p>
        </div>
    </div>
</section>

<section id="features">
    <h2>Key Features</h2>
    <p>✔ Organized Study Notes</p>
    <p>✔ Easy Navigation</p>
    <p>✔ Student Friendly Interface</p>
    <p>✔ Centralized Learning Platform</p>
</section>

<section id="quiz">
    <h2>Quick Quiz</h2>
    <p id="quiz-question"></p>
    <div id="quiz-options"></div>
    <p id="result"></p>
    <div class="coming-soon">
        More quizzes and study material will be uploaded soon! Stay tuned 📚✨
    </div>
</section>

<section id="feedback">
    <h2>Feedback</h2>
    <p>We would love to hear from you!</p>
    <textarea id="feedback-box" placeholder="Write your feedback here..."></textarea><br>
    <button id="feedback-btn">Submit</button>
    <div class="feedback-display" id="feedback-display"></div>
</section>

<section id="contact">
    <h2>Contact</h2>
    <p>Email: learnova@gmail.com</p>
    <p>Created by: Sneha Kumari, Yanshika Sharma, Preeti Bhandari</p> 
</section>

<footer>
    <p>© 2026 Learnova | Hackathon Project</p>
</footer>

<script>
// Welcome button
document.getElementById("start-btn").addEventListener("click", () => {
    alert("Welcome to Learnova! Start Learning Smart 📚");
});

// Quiz data
const quizQuestions = [
    { question: "What is i² (iota square)?", options: ["1", "-1", "0"], answer: "-1" },
    { question: "What is the derivative of x²?", options: ["x", "2x", "x²"], answer: "2x" },
    { question: "What is H₂O commonly known as?", options: ["Water", "Oxygen", "Hydrogen"], answer: "Water" }
];

let currentQuiz = 0;

// Load quiz
function loadQuiz() {
    const q = quizQuestions[currentQuiz];
    const questionEl = document.getElementById("quiz-question");
    const optionsEl = document.getElementById("quiz-options");

    questionEl.textContent = q.question;
    optionsEl.innerHTML = "";

    q.options.forEach(option => {
        const btn = document.createElement("button");
        btn.textContent = option;

        btn.addEventListener("click", () => checkAnswer(option));

        optionsEl.appendChild(btn);
    });

    document.getElementById("result").textContent = "";
}

// Check answer
function checkAnswer(selected) {
    const correct = quizQuestions[currentQuiz].answer;
    const resultEl = document.getElementById("result");

    if (selected === correct) {
        resultEl.textContent = "Correct! ✅";
        resultEl.style.color = "#27ae60";
    } else {
        resultEl.textContent = "Wrong Answer ❌ Try Again!";
        resultEl.style.color = "#e74c3c";
    }
}

// Feedback button
document.getElementById("feedback-btn").addEventListener("click", () => {
    const box = document.getElementById("feedback-box");
    const display = document.getElementById("feedback-display");

    if (box.value.trim()) {
        const p = document.createElement("p");
        p.textContent = box.value;
        display.appendChild(p);
        box.value = "";
        alert("Thank you for your feedback!");
    } else {
        alert("Please write something before submitting.");
    }
});

// Initialize quiz
loadQuiz();
</script>

</body>
</html>
            
       
        
        
        

   

   
